// ════════════════════════════════════════════════════════════════════════
// V3.2 — ARB//RADAR Prisma Schema
//
// PostgreSQL-compatible schema for data persistence.
// LIVE data is persisted via debounced writes (every 60s)
// to avoid exhausting Vercel serverless function quotas.
//
// V3.2: Added PriceSnapshot + DailyOHLC for historical accumulation.
// The Cerebro Táctico script saves every price tick to PriceSnapshot
// and aggregates daily OHLC data into DailyOHLC for charting.
//
// FALLBACK: If DATABASE_URL is not configured, the app
// automatically falls back to localStorage — zero config needed.
// ════════════════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Main application state snapshot — persisted every 60s when LIVE is active
model AppState {
  id        String   @id @default("main")
  instruments  String   // JSON — Instrument[]
  config       String   // JSON — Config
  position     String?  // JSON — Position | null
  transactions String   // JSON — Transaction[]
  lastUpdate   String?  // ISO timestamp of last data load
  rawInput     String?  // Last raw text input
  mepRate      Float?   // Last known MEP rate
  cclRate      Float?   // Last known CCL rate
  liveActive   Boolean  @default(false) // Whether LIVE was active at last persist
  iolLevel2Online Boolean @default(false) // V3.1: Whether IOL Level 2 data is available
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// External history records (imported from XLSX/CSV)
model ExternalHistory {
  id        String   @id @default(cuid())
  fecha     String   // DD/MM/YYYY
  ticker    String
  operacion String
  tem       Float    @default(0)
  precioConComision Float @default(0)
  duration  Float    @default(0)
  capitalNeto Float   @default(0)
  notas     String   @default("")
  gananciaAcumulada Float @default(0)
  createdAt DateTime @default(now())

  @@index([ticker])
}

/// Simulation records (rotation simulations)
model Simulation {
  id        String   @id @default(cuid())
  timestamp String
  fromTicker String
  toTicker   String
  sellPrice  Float
  buyPrice   Float
  sellPriceManual Boolean @default(false)
  buyPriceManual  Boolean @default(false)
  spreadNeto  Float
  spreadBruto Float
  evaluacion  String
  paybackDays Float
  nuevosNominales Float
  capitalNetoSalida Float
  capitalSobrante Float
  createdAt DateTime @default(now())
}

/// Keep User model for potential auth
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// ════════════════════════════════════════════════════════════════════════
/// V3.2 — MÓDULO DE ACUMULACIÓN HISTÓRICA
///
/// PriceSnapshot: Every price tick from the Cerebro Táctico motor.
/// Each row = one instrument at one point in time.
/// This is the RAW data that fuels the Historico tab charts.
///
/// DailyOHLC: Aggregated daily Open/High/Low/Close per ticker.
/// Built from PriceSnapshot data — one row per ticker per trading day.
/// Used for candlestick-style charts and technical analysis.
/// ════════════════════════════════════════════════════════════════════════

/// Raw price snapshot — one row per instrument per tick (~60s during market hours)
model PriceSnapshot {
  id        String   @id @default(cuid())
  ticker    String                // e.g. "S30O6", "T30J7"
  type      String                // "LECAP" or "BONCAP"
  price     Float                 // last_price per $1 VN
  bid       Float    @default(0)  // bid price per $1 VN
  ask       Float    @default(0)  // ask price per $1 VN
  tem       Float                 // Monthly TEM (percentage, e.g. 2.15)
  tir       Float    @default(0)  // TIR (equals TEM in our model)
  tna       Float    @default(0)  // Annualized TNA (percentage)
  spread    Float    @default(0)  // spread vs caución (percentage points)
  days      Int                   // days to expiry
  volume    Float    @default(0)  // notional ARS volume from data912
  change    Float    @default(0)  // daily change %
  // IOL Level 2 fields
  iolVolume        Float?         // cantidadOperada from IOL
  iolBid           Float?         // best bid from IOL
  iolAsk           Float?         // best ask from IOL
  iolStatus        String?        // "online" | "offline" | "no_data"
  iolLiquidityAlert Boolean?      // True when volume < 10% avg daily
  // Metadata
  source    String   @default("cerebro") // "cerebro" | "api_letras" | "manual"
  timestamp DateTime               // Exact time of the snapshot
  createdAt DateTime @default(now())

  @@index([ticker])
  @@index([timestamp])
  @@index([ticker, timestamp])
}

/// Daily OHLC aggregation — one row per ticker per trading day
model DailyOHLC {
  id        String   @id @default(cuid())
  ticker    String                // e.g. "S30O6", "T30J7"
  date      String                // YYYY-MM-DD (Argentina timezone)
  open      Float                 // First price of the day
  high      Float                 // Max price of the day
  low       Float                 // Min price of the day
  close     Float                 // Last price of the day
  openTEM   Float                 // First TEM of the day
  highTEM   Float                 // Max TEM of the day
  lowTEM    Float                 // Min TEM of the day
  closeTEM  Float                 // Last TEM of the day
  avgVolume Float    @default(0)  // Average notional volume
  avgIOLVolume Float?             // Average IOL volume (if available)
  tickCount Int       @default(0) // Number of PriceSnapshot ticks that day
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ticker, date])
  @@index([ticker])
  @@index([date])
}
